# ============================================================
# JARVIS Desktop Assistant - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control!

# --- Core AI (Required) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Voice / TTS ---
# Options: "edge" (free, good quality) or "elevenlabs" (premium, best quality)
TTS_ENGINE=edge
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Edge TTS voice options: en-US-GuyNeural (deep), en-US-ChristopherNeural, en-GB-RyanNeural
EDGE_TTS_VOICE=en-US-GuyNeural

# --- Gmail & Google Calendar (OAuth2) ---
# Download credentials.json from Google Cloud Console
# See: https://developers.google.com/gmail/api/quickstart/python
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GMAIL_MAX_RESULTS=20

# --- Slack ---
# Create a Slack app at https://api.slack.com/apps
# Required scopes: channels:history, channels:read, im:history, im:read, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_USER_TOKEN=xoxp-your-user-token

# --- Notion ---
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your-notion-key
# Comma-separated database IDs to monitor
NOTION_DATABASE_IDS=db-id-1,db-id-2

# --- HubSpot ---
# Get your API key from HubSpot Settings > Integrations > API Key
HUBSPOT_API_KEY=your-hubspot-api-key

# --- Server ---
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8550
